KIE_API_KEY=replace-with-your-kie-api-key
KIE_API_BASE=https://api.kie.ai
KIE_UPLOAD_BASE=https://kieai.redpandaai.co
KIE_TIMEOUT_SECONDS=120
KIE_MAX_RETRIES=3
KIE_MAX_UPLOAD_BYTES=104857600
# Required only for kie_upload_local_file:
# KIE_ALLOWED_UPLOAD_ROOT=/absolute/path/to/files
KIE_MCP_TRANSPORT=stdio
